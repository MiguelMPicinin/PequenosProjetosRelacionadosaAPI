<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PequenosProjetosRelacionadosaAPI.Views.RAWGPage"
             Title="Jogos (RAWG)">
    <VerticalStackLayout Spacing="15" Padding="20">
        <Entry x:Name="GameEntry" Placeholder="Digite o nome do jogo" />
        <Button Text="Buscar" Clicked="OnSearchClicked" />
        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" />
        <ScrollView>
            <VerticalStackLayout x:Name="ResultLayout" Spacing="10" />
        </ScrollView>
    </VerticalStackLayout>
</ContentPage>