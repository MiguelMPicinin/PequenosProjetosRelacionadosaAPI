<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PequenosProjetosRelacionadosaAPI.Views.CurrencyPage"
             Title="CurrencyPage">
    <VerticalStackLayout Spacing="15" Padding="20">
        <Entry x:Name="FromEntry" Placeholder="De (ex: USD)" />
        <Entry x:Name="ToEntry" Placeholder="Para (ex: BRL)" />
        <Entry x:Name="AmountEntry" Placeholder="Valor" Keyboard="Numeric" />
        <Button Text="Converter" Clicked="OnConvertClicked" />
        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" />
        <Label x:Name="ResultLabel" />
    </VerticalStackLayout>
</ContentPage>