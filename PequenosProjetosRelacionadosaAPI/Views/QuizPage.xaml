<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PequenosProjetosRelacionadosaAPI.Views.QuizPage"
             Title="QuizPage">
    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">
            <Button Text="Carregar Perguntas" Clicked="OnLoadQuestionsClicked" />
            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" />
            <VerticalStackLayout x:Name="QuestionsLayout" Spacing="15" />
            <Button x:Name="SubmitButton" Text="Enviar Respostas" Clicked="OnSubmitClicked" IsVisible="False" />
            <Label x:Name="ResultLabel" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>